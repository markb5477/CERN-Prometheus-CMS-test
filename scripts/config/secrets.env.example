# Copy to secrets.env (gitignored) and fill in. NEVER commit the real file.
# secrets.env is sourced by the DIST-mode scenarios. It holds NO password: run
# scripts/config/login.sh once per session and type it by hand -- that opens a
# multiplexed ssh master per host which every scenario reuses.

# SSH login user on the CERN hosts.
SSH_USER=mbrandt

# Fleet. Load = Avalanche generators, Collector = Prometheus. Space-separated hostnames.
# Twin uses the first 2 collectors; shard uses as many as SHARD_SET needs.
LOAD_HOSTS="cmx-rack-sw-01.cern.ch"
COLLECTOR_HOSTS="cmx-rack-sw-00.cern.ch"

# Where the repo (with bin/ staged) lives on each CERN host.
REMOTE_ROOT=/home/mbrandt/testingPrometheus/CERN-Prometheus-CMS-test

# Workload. Defaults come from the real board model in common.sh: 150 Outer-Tracker boards
# (2,100 params each) + 50 Inner-Tracker boards (11,300 each) = 200 targets, ~0.88M params.
# Leave MODULES/TOTAL unset to use the real detector; override only to test another scale.
# MODULES=200
# TOTAL=880000
SHARD_SET="1 2 4 8"

# ---- Optional knobs (env, not secrets - listed here as the one place they're documented) ----
# TSDB_ROOT: where the TSDB lives. Default = repo .native-data (safe locally). ON THE HPC point
#   this at NODE-LOCAL scratch (/tmp or local NVMe) - NEVER Lustre/GPFS/NFS (fsync-heavy write
#   path degrades on a network FS; warn_if_network_fs() flags it). Not /dev/shm: tmpfs would eat
#   the RAM this harness measures.
# TSDB_ROOT=/tmp/prom-tsdb
#
# RUN_PUSH=1: also run the opt-in pull-vs-push diagnostic (scenarios/baseline/push.sh) in
#   run_all.sh. Off by default - it's a diagnostic, not part of the core pull sweep.
# RUN_PUSH=1
#
# soak.sh compaction exercise (opt-in):
#   MIN_BLOCK=5m  -> force short block cuts + compaction inside a short soak (hidden 3.13 flags).
#   RETENTION=1h  -> cap on-disk history.
# MIN_BLOCK=5m
# RETENTION=1h
#
# spike.sh section granularity (defaults model the real detector - Matteo: ~6 OT + ~3 IT sections):
#   OT_SECTIONS=6 / IT_SECTIONS=3  -> how many equal chunks each subsystem powers on/off in.
#   DESCEND=1                      -> also walk the staircase back down (power-off); 0 = up only.
#   HOLD=60                        -> seconds held at each section level before measuring.
# OT_SECTIONS=6
# IT_SECTIONS=3
